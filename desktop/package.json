{
  "name": "divulgeai-desktop",
  "version": "2.0.0",
  "description": "DivulgeAI Desktop \u2014 AI-powered dental caries detection",
  "license": "GPL-3.0-or-later",
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5174 && electron .\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@techstark/opencv-js": "^5.0.0-release.1",
    "onnxruntime-web": "^1.16.0",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "31.7.7",
    "electron-builder": "^24.13.3",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.divulgeai.desktop",
    "productName": "DivulgeAI",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*"
    ],
    "directories": {
      "buildResources": "public",
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName} Setup ${version}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/icon.icns",
      "category": "public.app-category.medical"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "public/icon.png",
      "category": "Science"
    },
    "asarUnpack": [
      "public/dental_unet_resnet50_merged.onnx",
      "public/ort/**",
      "public/opencv/**",
      "node_modules/onnxruntime-web/**"
    ],
    "extraResources": []
  }
}